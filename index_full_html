<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>💕 Happy 50th Monthsary 💕</title>
<link href="https://fonts.googleapis.com/css2?family=Boogaloo&family=Pacifico&family=Nunito:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --pink: #ff6b9d;
    --pink-light: #ffd6e7;
    --peach: #ffb347;
    --yellow: #ffe66d;
    --mint: #a8e6cf;
    --purple: #c3aef4;
    --white: #fff9fb;
    --dark: #3d2c4e;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: 'Nunito', sans-serif;
    background: var(--white);
    color: var(--dark);
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* === FLOATING HEARTS === */
  .hearts-bg { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
  .heart-float { position: absolute; opacity: 0.13; animation: floatUp linear infinite; }
  @keyframes floatUp {
    0%   { transform: translateY(110vh) rotate(0deg);   opacity: 0.13; }
    100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
  }

  /* === PAGES === */
  .page {
    display: none; min-height: 100vh; padding: 28px 20px 44px;
    position: relative; z-index: 1;
    flex-direction: column; align-items: center; justify-content: center; text-align: center;
  }
  .page.active { display: flex; }

  /* NAV DOTS */
  .nav-dots { position: fixed; top: 14px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 50; }
  .dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,107,157,.25); transition: all .3s; }
  .dot.active { background: var(--pink); transform: scale(1.3); }

  /* ===== PAGE 1 ===== */
  #page1 { background: linear-gradient(145deg, #fff0f6 0%, #fce4f5 55%, #ffe8f0 100%); }

  /* ---- Badge 50 ---- */
  .badge-wrap {
    position: relative;
    width: clamp(190px, 46vw, 268px);
    height: clamp(190px, 46vw, 268px);
    margin: 0 auto 22px;
  }
  .badge-ring {
    position: absolute; inset: 0; border-radius: 50%;
    background: conic-gradient(#ff6b9d, #ffb347, #ffe66d, #a8e6cf, #c3aef4, #ff85b8, #ff6b9d);
    animation: spinRing 5s linear infinite;
  }
  @keyframes spinRing { to { transform: rotate(360deg); } }

  .badge-inner {
    position: absolute; inset: 7px; border-radius: 50%;
    background: linear-gradient(145deg, #ff85b8 0%, #ff4d8a 55%, #d42870 100%);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    box-shadow: 0 8px 36px rgba(255,77,138,.45), inset 0 -5px 14px rgba(0,0,0,.15), inset 0 3px 8px rgba(255,255,255,.2);
    animation: floatBadge 3.2s ease-in-out infinite;
  }
  @keyframes floatBadge {
    0%,100% { transform: translateY(0)   scale(1); }
    50%     { transform: translateY(-7px) scale(1.03); }
  }

  .badge-num {
    font-family: 'Pacifico', cursive;
    font-size: clamp(3.8rem, 14vw, 7rem);
    color: #fff; line-height: 1;
    text-shadow: 3px 5px 0 rgba(0,0,0,.2), -1px -1px 0 rgba(255,255,255,.25);
    letter-spacing: -3px;
  }
  .badge-label {
    font-family: 'Boogaloo', cursive;
    font-size: clamp(.7rem, 2.4vw, .95rem);
    color: rgba(255,255,255,.9);
    letter-spacing: 2.5px; text-transform: uppercase; margin-top: -3px;
  }

  /* sparkles */
  .badge-star { position: absolute; animation: starPop 2s ease-in-out infinite alternate; }
  .badge-star:nth-child(1) { top: -5%;   left: 10%;  font-size: clamp(1rem,3vw,1.5rem); animation-delay: 0s;   }
  .badge-star:nth-child(2) { top: 3%;    right: 1%;  font-size: clamp(.9rem,2.5vw,1.3rem); animation-delay: .45s; }
  .badge-star:nth-child(3) { bottom: 1%; left: -2%;  font-size: clamp(.9rem,2.5vw,1.3rem); animation-delay: .9s;  }
  .badge-star:nth-child(4) { bottom:-5%; right:10%;  font-size: clamp(1rem,3vw,1.5rem); animation-delay: 1.3s; }
  @keyframes starPop {
    0%   { transform: scale(.8) rotate(-10deg); opacity: .6; }
    100% { transform: scale(1.4) rotate(10deg);  opacity: 1; }
  }

  .main-title {
    font-family: 'Boogaloo', cursive;
    font-size: clamp(2.2rem, 7vw, 4.2rem);
    color: var(--pink); line-height: 1.1; margin-bottom: 10px;
    text-shadow: 2px 3px 0 rgba(255,107,157,.18);
  }
  .sub-text { font-size: clamp(.9rem,3vw,1.15rem); color: #a07090; margin-bottom: 14px; line-height: 1.65; }
  /* Tenor embed wrapper */
  .cat-gif-wrap {
    width: clamp(90px, 24vw, 150px);
    aspect-ratio: 1;
    margin: 10px auto;
    border-radius: 18px;
    overflow: hidden;
    display: block;
  }
  .tenor-embed {
    width: 100%; height: 100%;
    border: none; border-radius: 18px;
    pointer-events: none; /* no interaction on decorative ones */
  }

  /* Keep old .cat-gif for any remaining img tags */
  .cat-gif { width: clamp(90px,24vw,150px); border-radius: 18px; margin: 12px auto; display: block; }

  .btn-primary {
    background: linear-gradient(135deg, var(--pink), #ff4d8a);
    color: white; border: none; padding: 13px 34px; border-radius: 50px;
    font-family: 'Boogaloo', cursive; font-size: clamp(1.1rem,4vw,1.4rem);
    cursor: pointer; box-shadow: 0 6px 20px rgba(255,107,157,.4); transition: all .2s; margin-top: 14px;
  }
  .btn-primary:hover  { transform: translateY(-3px) scale(1.05); box-shadow: 0 10px 28px rgba(255,107,157,.5); }
  .btn-primary:active { transform: scale(.97); }

  /* ===== PAGE 2 ===== */
  #page2 { background: linear-gradient(135deg, #fff5e0 0%, #fce4f5 100%); }

  .question-text {
    font-family: 'Boogaloo', cursive;
    font-size: clamp(1.8rem,6vw,3rem); color: var(--dark); margin-bottom: 24px; line-height: 1.2;
  }

  /* Fixed arena for button movement */
  .love-arena {
    position: relative;
    width: min(360px, 90vw);
    height: 190px;
    margin: 0 auto;
  }

  #btn-yes {
    position: absolute;
    background: linear-gradient(135deg, var(--mint), #57c99a);
    color: white; border: none; border-radius: 50px;
    font-family: 'Boogaloo', cursive; font-size: 1.4rem;
    padding: 14px 32px; cursor: pointer;
    box-shadow: 0 6px 20px rgba(100,200,150,.4);
    transition: transform .3s cubic-bezier(.34,1.56,.64,1), font-size .3s, left .35s, top .35s;
    white-space: nowrap;
  }

  #btn-no {
    position: absolute;
    background: linear-gradient(135deg, #f0a0a0, #e06060);
    color: white; border: none; border-radius: 50px;
    font-family: 'Boogaloo', cursive; font-size: 1.3rem;
    padding: 12px 26px; cursor: pointer;
    box-shadow: 0 4px 12px rgba(220,100,100,.3);
    transition: left .28s ease, top .28s ease, font-size .2s, padding .2s;
    white-space: nowrap;
  }

  #yes-msg { display: none; margin-top: 22px; }
  .yay-msg {
    font-family: 'Boogaloo', cursive; font-size: clamp(1.2rem,4.5vw,1.9rem);
    color: var(--pink); animation: fadeInUp .45s ease; margin: 10px 0;
  }
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ===== PAGE 3 ===== */
  #page3 { background: linear-gradient(135deg, #e8f4ff 0%, #f0e8ff 100%); padding-bottom: 44px; }

  .game-section { display: none; width: 100%; max-width: 500px; flex-direction: column; align-items: center; }
  .game-section.active-game { display: flex; }

  .section-title { font-family: 'Boogaloo', cursive; font-size: clamp(1.5rem,5vw,2.2rem); color: var(--purple); margin-bottom: 12px; }
  .step-indicator { font-family: 'Boogaloo', cursive; font-size: .95rem; color: #c0a0d0; margin-bottom: 4px; }

  /* Shape Match */
  .shape-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin: 12px 0; max-width: 320px; }
  .shape-card {
    width: 68px; height: 68px; display: flex; align-items: center; justify-content: center;
    font-size: 2rem; background: white; border-radius: 14px; cursor: pointer;
    border: 3px solid transparent; transition: all .2s; box-shadow: 0 3px 10px rgba(0,0,0,.08); user-select: none;
  }
  .shape-card:hover    { transform: scale(1.08); }
  .shape-card.selected { border-color: var(--pink); background: var(--pink-light); transform: scale(1.08); }
  .shape-card.matched  { border-color: var(--mint); background: #d4f5e5; animation: matchPop .4s ease; pointer-events: none; }
  .shape-card.wrong    { border-color: #ff6b6b; background: #ffe0e0; animation: shake .4s ease; }
  @keyframes matchPop { 0% { transform: scale(1.2); } 100% { transform: scale(1); } }
  @keyframes shake { 0%,100% { transform: translateX(0); } 25% { transform: translateX(-6px); } 75% { transform: translateX(6px); } }

  .game-score { font-family: 'Boogaloo', cursive; font-size: 1.25rem; color: var(--pink); margin: 6px 0; }
  .game-nav   { display: flex; gap: 12px; margin-top: 16px; flex-wrap: wrap; justify-content: center; }

  .btn-secondary {
    background: linear-gradient(135deg, var(--purple), #9d7de8); color: white;
    border: none; padding: 10px 24px; border-radius: 50px;
    font-family: 'Boogaloo', cursive; font-size: 1.05rem; cursor: pointer;
    box-shadow: 0 4px 14px rgba(160,120,240,.35); transition: all .2s;
  }
  .btn-secondary:hover { transform: translateY(-2px); }

  .btn-skip {
    background: rgba(200,180,220,.3); color: #9070b0;
    border: 2px dashed #c0a0d0; padding: 9px 22px; border-radius: 50px;
    font-family: 'Boogaloo', cursive; font-size: 1rem; cursor: pointer; transition: all .2s;
  }
  .btn-skip:hover { background: rgba(200,180,220,.55); }

  /* Quiz */
  .quiz-card { background: white; border-radius: 20px; padding: 20px; box-shadow: 0 4px 20px rgba(0,0,0,.08); width: 100%; max-width: 460px; }
  .quiz-q { font-size: clamp(.95rem,3.5vw,1.12rem); font-weight: 700; color: var(--dark); margin-bottom: 14px; line-height: 1.5; white-space: pre-line; }
  .quiz-progress { font-size: .85rem; color: #b090c0; margin-bottom: 10px; }
  .quiz-options  { display: flex; flex-direction: column; gap: 10px; }
  .quiz-opt {
    background: var(--pink-light); border: 2px solid transparent; border-radius: 12px;
    padding: 11px 15px; cursor: pointer; font-family: 'Nunito', sans-serif;
    font-size: clamp(.88rem,3vw,1rem); font-weight: 600; color: var(--dark); transition: all .2s; text-align: left;
  }
  .quiz-opt:hover    { border-color: var(--pink); background: #ffe0ef; transform: translateX(4px); }
  .quiz-opt.selected { border-color: var(--pink); background: linear-gradient(135deg,#ffd6e7,#ffb3d0); color: #9d2060; }
  .quiz-next {
    margin-top: 14px; background: linear-gradient(135deg, var(--purple), #9d7de8);
    color: white; border: none; padding: 11px 28px; border-radius: 50px;
    font-family: 'Boogaloo', cursive; font-size: 1.1rem; cursor: pointer;
    transition: all .2s; box-shadow: 0 4px 14px rgba(160,120,240,.35);
  }
  .quiz-next:hover    { transform: translateY(-2px); }
  .quiz-next:disabled { opacity: .45; cursor: not-allowed; transform: none; }

  /* Free text answer */
  .quiz-textarea {
    width: 100%; min-height: 90px; border: 2px solid var(--pink-light);
    border-radius: 14px; padding: 12px 14px; font-family: 'Nunito', sans-serif;
    font-size: clamp(.9rem,3vw,1rem); color: var(--dark); resize: vertical;
    transition: border-color .2s; outline: none; background: #fff8fb;
    line-height: 1.55;
  }
  .quiz-textarea:focus { border-color: var(--pink); background: white; }
  .quiz-textarea::placeholder { color: #d0a0c0; }

  /* GIF / image upload question */
  .gif-search-wrap { width: 100%; }
  .gif-tabs { display: flex; gap: 8px; margin-bottom: 12px; }
  .gif-tab {
    flex: 1; padding: 9px 0; border-radius: 12px; border: 2px solid transparent;
    font-family: 'Boogaloo', cursive; font-size: 1rem; cursor: pointer;
    background: var(--pink-light); color: #9d2060; transition: all .2s;
  }
  .gif-tab.active { background: var(--pink); color: white; border-color: var(--pink); }

  .gif-search-row { display: flex; gap: 8px; margin-bottom: 10px; }
  .gif-search-input {
    flex: 1; padding: 10px 14px; border: 2px solid var(--pink-light);
    border-radius: 12px; font-family: 'Nunito', sans-serif; font-size: .95rem;
    outline: none; background: #fff8fb; color: var(--dark); transition: border-color .2s;
  }
  .gif-search-input:focus { border-color: var(--pink); }
  .gif-search-btn {
    padding: 10px 16px; background: linear-gradient(135deg, var(--pink), #ff4d8a);
    color: white; border: none; border-radius: 12px;
    font-family: 'Boogaloo', cursive; font-size: .95rem; cursor: pointer;
    white-space: nowrap; transition: all .2s;
  }
  .gif-search-btn:hover { transform: scale(1.04); }

  .gif-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px;
    max-height: 220px; overflow-y: auto; border-radius: 12px;
  }
  .gif-grid img {
    width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 8px;
    cursor: pointer; border: 3px solid transparent; transition: all .2s;
  }
  .gif-grid img:hover { border-color: var(--purple); transform: scale(1.04); }
  .gif-grid img.gif-selected { border-color: var(--pink); box-shadow: 0 0 0 2px var(--pink); }

  .gif-loading { color: #b090c0; font-size: .9rem; text-align: center; padding: 20px 0; }
  .gif-error   { color: #e06060; font-size: .88rem; text-align: center; padding: 10px 0; }

  /* upload area */
  .upload-area {
    border: 2.5px dashed var(--pink-light); border-radius: 16px;
    padding: 28px 16px; text-align: center; cursor: pointer;
    transition: all .2s; background: #fff8fb;
  }
  .upload-area:hover { border-color: var(--pink); background: #fff0f6; }
  .upload-area p { font-size: .9rem; color: #b090c0; margin-top: 8px; }
  .upload-area .upload-icon { font-size: 2.4rem; }
  #uploadInput { display: none; }

  .media-preview {
    width: 100%; max-height: 200px; border-radius: 14px;
    object-fit: contain; margin-top: 8px; display: none;
    border: 3px solid var(--pink-light);
  }
  .media-clear {
    margin-top: 8px; font-size: .85rem; color: #e06060; cursor: pointer;
    background: none; border: none; font-family: 'Boogaloo', cursive; font-size: .95rem;
  }

  /* Result */
  .result-card { background: white; border-radius: 24px; padding: 20px; box-shadow: 0 6px 28px rgba(0,0,0,.1); width: 100%; max-width: 460px; margin-top: 10px; }
  .result-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 10px 0; border-bottom: 1px dashed var(--pink-light); gap: 8px; }
  .result-item:last-child { border-bottom: none; }
  .result-q { color: #a07090; font-size: .83rem; flex-shrink: 0; text-align: left; min-width: 90px; }
  .result-a { font-weight: 700; color: var(--pink); font-family: 'Boogaloo', cursive; font-size: .98rem; text-align: right; word-break: break-word; }
  .result-media { width: 90px; height: 70px; border-radius: 10px; object-fit: cover; border: 2px solid var(--pink-light); }

  /* === TOAST === */
  #toast {
    position: fixed; bottom: 24px; left: 50%;
    transform: translateX(-50%) translateY(30px);
    background: white; border-radius: 20px;
    padding: 14px 22px;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
    z-index: 500; opacity: 0;
    transition: all .38s cubic-bezier(.34,1.56,.64,1);
    display: flex; align-items: center; gap: 12px;
    max-width: 88vw; pointer-events: none;
    border: 2px solid var(--pink-light);
  }
  #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  #toast img  { width: 54px; height: 54px; border-radius: 10px; object-fit: cover; flex-shrink: 0; }
  #toast p    { font-family: 'Boogaloo', cursive; font-size: 1rem; color: var(--dark); margin: 0; text-align: left; }

  /* === CONFETTI === */
  .confetti-piece {
    position: fixed; border-radius: 2px; pointer-events: none; z-index: 999;
    animation: confettiFall linear forwards;
  }
  @keyframes confettiFall {
    0%   { transform: translateY(-20px) rotate(0deg);   opacity: 1; }
    100% { transform: translateY(105vh) rotate(720deg); opacity: 0; }
  }

  /* === KASETA === */
  iframe#kaseta-frame { position: fixed; inset: 0; width: 100%; height: 100%; border: none; z-index: 9999; display: none; }
  #kaseta-close {
    display: none; position: fixed; top: 14px; left: 50%; transform: translateX(-50%);
    z-index: 10000; background: rgba(255,107,157,.92); color: white;
    border: none; border-radius: 50px; padding: 8px 22px;
    font-family: 'Boogaloo', cursive; font-size: 1rem; cursor: pointer; backdrop-filter: blur(4px);
  }

  @media (max-width: 380px) {
    .shape-card { width: 58px; height: 58px; font-size: 1.7rem; }
    .shape-grid { gap: 7px; max-width: 272px; }
    .love-arena { height: 210px; }
  }
</style>
</head>
<body>

<div class="hearts-bg" id="heartsBg"></div>

<div class="nav-dots">
  <div class="dot active" id="dot1"></div>
  <div class="dot" id="dot2"></div>
  <div class="dot" id="dot3"></div>
</div>

<!-- TOAST -->
<div id="toast">
  <img id="toastImg" class="gif-asset" data-gif="cat-sad" style="width:56px;height:56px;border-radius:10px;object-fit:cover;flex-shrink:0;" alt="sad cat">
  <p id="toastMsg">Jangan gitu dooongg 😿</p>
</div>

<!-- ===== PAGE 1 ===== -->
<div class="page active" id="page1">
  <div class="badge-wrap">
    <div class="badge-ring"></div>
    <div class="badge-inner">
      <span class="badge-num">50</span>
      <span class="badge-label">monthsary</span>
    </div>
    <span class="badge-star">✨</span>
    <span class="badge-star">🌸</span>
    <span class="badge-star">⭐</span>
    <span class="badge-star">💖</span>
  </div>

  <h1 class="main-title">Happy 50th<br>Monthsary! 🎉</h1>
  <p class="sub-text">
    50 bulan penuh tawa, drama receh,<br>
    dan cinta yang makin gede tiap harinya 💕
  </p>
  <!-- Page 1: cute love cat -->
  <img class="cat-gif gif-asset" data-gif="cat-love" style="width:clamp(90px,24vw,150px)" alt="cat-love">
  <p class="sub-text" style="font-size:.88rem; margin-top:0;">sudah 4 tahun 2 bulan lho! 🥺</p>
  <button class="btn-primary" onclick="goToPage(2)">Next →</button>
</div>

<!-- ===== PAGE 2 ===== -->
<div class="page" id="page2">
  <!-- Page 2: cute curious cat -->
  <img class="cat-gif gif-asset" data-gif="cat-curious" style="width:clamp(90px,24vw,150px)" alt="cat-curious">
  <h2 class="question-text">do yu stil lov me?<br>🥺💕</h2>

  <div class="love-arena" id="loveArena">
    <button id="btn-yes" onclick="yesClicked()">Yes!! 💖</button>
    <button id="btn-no"  onclick="noClicked()">No 😤</button>
  </div>

  <div id="yes-msg">
    <p class="yay-msg" id="yes-text">Yayyy I knew it!! 🎉💕</p>
    <!-- Page 2 yes: happy cat -->
    <img class="cat-gif gif-asset" data-gif="cat-happy" style="width:130px" alt="cat-happy">
    <button class="btn-primary" onclick="goToPage(3)" style="margin-top:14px;">Main Game Yuk! 🎮</button>
  </div>

  <!-- hidden "no" reaction cat, shows after 5 no clicks -->
  <div id="no-cat" style="display:none; margin-top:12px;">
    <img class="cat-gif gif-asset" data-gif="cat-judging" style="width:110px" alt="cat-judging">
    <p style="font-family:'Boogaloo',cursive; color:#e06060; font-size:1rem; margin-top:6px;">beneran mau bilang no?? 😾</p>
  </div>
</div>

<!-- ===== PAGE 3 ===== -->
<div class="page" id="page3">

  <!-- Shape Match -->
  <div class="game-section active-game" id="game1">
    <p class="step-indicator">Mini Game 1 dari 2 🎮</p>
    <h2 class="section-title">Cocokkan Shape-nya! 🧩</h2>
    <p style="color:#a07090; font-size:.9rem; margin-bottom:6px;">Pilih 2 kartu yang sama!</p>
    <div class="game-score">⭐ Score: <span id="matchScore">0</span> &nbsp;|&nbsp; Moves: <span id="moves">0</span></div>
    <div class="shape-grid" id="shapeGrid"></div>

    <div id="matchResult" style="display:none; margin-top:10px;">
      <p class="yay-msg">Jago banget! 🎉</p>
      <!-- Shape match win: celebrate cat -->
      <img class="cat-gif gif-asset" data-gif="cat-celebrate" style="width:110px" alt="cat-celebrate">
    </div>

    <div class="game-nav">
      <button class="btn-secondary" onclick="initShapeGame()">🔄 Restart</button>
      <button class="btn-secondary" id="nextGameBtn" onclick="goToGame(2)" style="display:none;">Quiz! 📝</button>
      <button class="btn-skip" onclick="skipShapeGame()">Skip aja 😬</button>
    </div>
  </div>

  <!-- Quiz -->
  <div class="game-section" id="game2">
    <p class="step-indicator">Mini Game 2 dari 2 📝</p>
    <h2 class="section-title">Quiz Kita! 💑</h2>
    <p style="color:#a07090; font-size:.9rem; margin-bottom:10px;">Jawab jujur ya sayang!</p>

    <div class="quiz-card" id="quizCard">
      <p class="quiz-progress" id="quizProgress">Pertanyaan 1 dari 6</p>
      <p class="quiz-q" id="quizQuestion"></p>
      <div class="quiz-options" id="quizOptions"></div>
      <button class="quiz-next" id="quizNextBtn" onclick="nextQuestion()" disabled>Selanjutnya →</button>
    </div>

    <div id="quizResult" style="display:none; width:100%; max-width:460px;">
      <p class="yay-msg" style="color:var(--purple);">Selesai! Ini jawabanmu 🥰</p>
      <!-- Quiz done: heart cat -->
      <img class="cat-gif gif-asset" data-gif="cat-heart" style="width:110px" alt="cat-heart">
      <div class="result-card" id="resultCard"></div>
      <button class="btn-primary" onclick="showKaseta()" style="margin-top:20px; font-size:1.1rem;">🎵 Surprise Terakhir! 💕</button>
    </div>
  </div>

</div>

<iframe id="kaseta-frame" src="" allowfullscreen allow="autoplay"></iframe>
<button id="kaseta-close" onclick="closeKaseta()">✕ Tutup</button>

<script>

// ======= OFFLINE GIF ASSETS =======
const GIFS = {
  "cat-love": "data:image/gif;base64,",
  "cat-curious": "data:image/gif;base64,",
  "cat-happy": "data:image/gif;base64,",
  "cat-sad": "data:image/gif;base64,",
  "cat-celebrate": "data:image/gif;base64,",
  "cat-heart": "data:image/gif;base64,",
  "cat-judging": "data:image/gif;base64,",
};

// Set all offline GIF assets
function initGifs(){
  document.querySelectorAll('.gif-asset[data-gif]').forEach(el => {
    el.src = GIFS[el.dataset.gif] || '';
  });
}
window.addEventListener('DOMContentLoaded', initGifs);

// ======= HEARTS =======
const heartsBg = document.getElementById('heartsBg');
['💕','💖','💗','🌸','✨','💝','🩷','💓'].forEach((e,i) => {
  for(let j=0; j<2; j++){
    const h = document.createElement('div');
    h.className='heart-float'; h.textContent=e;
    h.style.left = Math.random()*100+'%';
    h.style.fontSize = (.8+Math.random()*1.1)+'rem';
    h.style.animationDuration = (9+Math.random()*11)+'s';
    h.style.animationDelay   = (Math.random()*12)+'s';
    heartsBg.appendChild(h);
  }
});

// ======= PAGE NAV =======
function goToPage(n){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.dot').forEach(d=>d.classList.remove('active'));
  document.getElementById('page'+n).classList.add('active');
  document.getElementById('dot'+n).classList.add('active');
  window.scrollTo(0,0);
  if(n===2) setTimeout(initLoveLayout,60);
  if(n===3) initShapeGame();
}

// ======= LOVE BUTTONS =======
let yesScale = 1, noCount = 0;

function initLoveLayout(){
  const arena = document.getElementById('loveArena');
  const aw = arena.offsetWidth, ah = arena.offsetHeight;
  const yes = document.getElementById('btn-yes');
  const no  = document.getElementById('btn-no');
  // yes: left-centre, no: right-centre
  yes.style.left = Math.round(aw*0.08)+'px';
  yes.style.top  = Math.round((ah - yes.offsetHeight)/2)+'px';
  yes.style.transform = 'none';

  no.style.left = Math.round(aw*0.58)+'px';
  no.style.top  = Math.round((ah - no.offsetHeight)/2)+'px';
  no.style.transform = 'none';
}

const yesMessages = [
  "Yayyy I knew it!! 🎉💕",
  "MASIH MASIH MASIH!! 🥰",
  "Tentu iyalah sayangku! 💖",
  "Awww makasih ya! 🥺💕",
  "Aku juga masih cinta kamu! 💗",
];

function yesClicked(){
  yesScale = Math.min(yesScale + 0.22, 2.7);
  const yes = document.getElementById('btn-yes');
  yes.style.transformOrigin='center center';
  yes.style.transform=`scale(${yesScale})`;
  yes.style.fontSize = Math.min(1.4+(yesScale-1)*0.35, 2.5)+'rem';

  const msg = document.getElementById('yes-msg');
  document.getElementById('yes-text').textContent = yesMessages[Math.min(noCount, yesMessages.length-1)];
  msg.style.display='block';
  confettiBurst();
}

function noClicked(){
  noCount++;
  const arena = document.getElementById('loveArena');
  const aw = arena.offsetWidth, ah = arena.offsetHeight;
  const yes = document.getElementById('btn-yes');
  const no  = document.getElementById('btn-no');

  const noScale = Math.max(0.45, 1 - noCount*0.08);
  no.style.fontSize = (noScale*1.3)+'rem';
  no.style.padding  = (noScale*12)+'px '+(noScale*26)+'px';

  // Compute yes button bounding box (approx)
  const yesCx = yes.offsetLeft + yes.offsetWidth/2;
  const yesCy = yes.offsetTop  + yes.offsetHeight/2;

  // Try positions — keep far from yes
  const noW = no.offsetWidth  || 100;
  const noH = no.offsetHeight || 44;
  let best=null, bestDist=-1;
  for(let t=0;t<50;t++){
    const px = Math.random() * Math.max(1, aw - noW);
    const py = Math.random() * Math.max(1, ah - noH);
    const cx = px + noW/2, cy = py + noH/2;
    const d  = Math.hypot(cx-yesCx, cy-yesCy);
    if(d > bestDist){ bestDist=d; best={px,py}; }
    if(d > 120) break;
  }
  no.style.left = best.px+'px';
  no.style.top  = best.py+'px';
  no.style.transform = 'none';

  // grow yes a little
  yesScale = Math.min(yesScale+0.10, 2.7);
  yes.style.transformOrigin='center center';
  yes.style.transform=`scale(${yesScale})`;

  // Sad cat toast + reveal no-cat at exactly 5 clicks
  if(noCount===5){
    showToast('Kok gitu sih... kucingnya ikut sedih 😿');
    document.getElementById('no-cat').style.display='block';
  }
}

// ======= TOAST =======
let toastTimer=null;
function showToast(msg){
  const t = document.getElementById('toast');
  document.getElementById('toastMsg').textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(()=>t.classList.remove('show'), 3800);
}

// ======= CONFETTI =======
function confettiBurst(){
  const cols=['#ff6b9d','#ffe66d','#a8e6cf','#c3aef4','#ffb347','#ffd6e7'];
  for(let i=0;i<38;i++){
    const c=document.createElement('div');
    c.className='confetti-piece';
    c.style.left=(15+Math.random()*70)+'vw';
    c.style.top='0';
    c.style.width =(5+Math.random()*8)+'px';
    c.style.height=(5+Math.random()*10)+'px';
    c.style.background=cols[Math.floor(Math.random()*cols.length)];
    c.style.animationDuration=(2+Math.random()*2)+'s';
    c.style.animationDelay=(Math.random()*.5)+'s';
    document.body.appendChild(c);
    setTimeout(()=>c.remove(),4500);
  }
}

// ======= SHAPE MATCH =======
const allEmojis=['🐱','🌸','⭐','🦋','🍓','🌈','🎀','🍩'];
let flipped=[],matched=0,moves=0,canFlip=true;

function initShapeGame(){
  const grid=document.getElementById('shapeGrid');
  const arr=[...allEmojis,...allEmojis];
  for(let i=arr.length-1;i>0;i--){
    const j=Math.floor(Math.random()*(i+1));
    [arr[i],arr[j]]=[arr[j],arr[i]];
  }
  flipped=[];matched=0;moves=0;canFlip=true;
  document.getElementById('matchScore').textContent=0;
  document.getElementById('moves').textContent=0;
  document.getElementById('matchResult').style.display='none';
  document.getElementById('nextGameBtn').style.display='none';
  grid.innerHTML='';
  arr.forEach(emoji=>{
    const card=document.createElement('div');
    card.className='shape-card'; card.textContent='?'; card.dataset.emoji=emoji;
    card.addEventListener('click',()=>flipCard(card));
    grid.appendChild(card);
  });
}

function flipCard(card){
  if(!canFlip||card.classList.contains('matched')||card.classList.contains('selected')) return;
  card.textContent=card.dataset.emoji; card.classList.add('selected'); flipped.push(card);
  if(flipped.length===2){
    canFlip=false; moves++;
    document.getElementById('moves').textContent=moves;
    setTimeout(checkMatch,680);
  }
}

function checkMatch(){
  const [a,b]=flipped;
  if(a.dataset.emoji===b.dataset.emoji){
    a.classList.replace('selected','matched'); b.classList.replace('selected','matched');
    matched++;
    document.getElementById('matchScore').textContent=Math.max(0,allEmojis.length*15-moves*8+matched*10);
    if(matched===allEmojis.length){
      document.getElementById('matchResult').style.display='block';
      document.getElementById('nextGameBtn').style.display='inline-block';
      confettiBurst();
    }
  } else {
    a.classList.add('wrong'); b.classList.add('wrong');
    setTimeout(()=>{
      a.classList.remove('selected','wrong'); a.textContent='?';
      b.classList.remove('selected','wrong'); b.textContent='?';
    },480);
  }
  flipped=[]; canFlip=true;
}

function skipShapeGame(){
  showToast('Dikit lagi lho... ya sudahlah 😿');
  setTimeout(()=>goToGame(2), 1500);
}

function goToGame(n){
  document.querySelectorAll('.game-section').forEach(g=>g.classList.remove('active-game'));
  document.getElementById('game'+n).classList.add('active-game');
  window.scrollTo(0,0);
  if(n===2) initQuiz();
}

// ======= QUIZ =======
// type: 'choice' | 'text' | 'media'
const quizData=[
  { type:'choice', q:"1. Siapa yang lebih bisa inget hal-hal penting? (alias ngga pelupa?) 😅",
    opts:["Aku dong!","Kamu pastinya~","Sama-sama pelupa sih wkwk","Tergantung penting buat siapa 😂"] },
  { type:'choice', q:"2. Siapa yang minum air putih lebih banyak? 💧",
    opts:["Aku! Udah kayak ikan 🐟","Kamu sih lebih rajin","Dua-duanya kurang hehe","Sama aja sih kayaknya"] },
  { type:'choice', q:"3. Siapa yang lebih sering/banyak jam tidur? 😴",
    opts:["Aku! Tidur is life 💤","Kamu jelas banget 😂","Sama-sama tukang tidur","Tergantung hari sih"] },
  { type:'choice', q:"4. Siapa yang lebih manja? 🥺",
    opts:["Aku ngaku deh wkwk","Kamu jelas lebih manja!","Dua-duanya sama manjanya 🥹","Gantian tergantung mood 😆"] },
  { type:'text', q:"5. Apa habit-ku yang paling aneh menurut kamu, tapi aku pretend itu normal? 🤔",
    placeholder:"Ceritain di sini ya, jujur boleh wkwk..." },
  { type:'media', q:"6. Kalo aku jadi meme, meme apa yang paling cocok? 😂\nPaste URL GIF dari Tenor/Giphy, atau upload gambar!" },
];

let currentQ=0, answers=[];

function initQuiz(){
  currentQ=0; answers=new Array(quizData.length).fill(null);
  document.getElementById('quizResult').style.display='none';
  document.getElementById('quizCard').style.display='block';
  renderQuestion();
}

function renderQuestion(){
  const d=quizData[currentQ];
  document.getElementById('quizProgress').textContent=`Pertanyaan ${currentQ+1} dari ${quizData.length}`;
  document.getElementById('quizQuestion').textContent=d.q;
  const oc=document.getElementById('quizOptions'); oc.innerHTML='';
  const nb=document.getElementById('quizNextBtn');
  nb.textContent=currentQ===quizData.length-1?'Lihat Hasil 🎉':'Selanjutnya →';

  if(d.type==='choice'){
    nb.disabled=!answers[currentQ];
    d.opts.forEach(opt=>{
      const b=document.createElement('button');
      b.className='quiz-opt'+(answers[currentQ]===opt?' selected':'');
      b.textContent=opt;
      b.onclick=()=>selectOption(b,opt);
      oc.appendChild(b);
    });

  } else if(d.type==='text'){
    nb.disabled=!answers[currentQ];
    const ta=document.createElement('textarea');
    ta.className='quiz-textarea';
    ta.placeholder=d.placeholder||'Tulis jawabanmu di sini...';
    ta.value=answers[currentQ]||'';
    ta.oninput=()=>{
      answers[currentQ]=ta.value.trim()||null;
      nb.disabled=!answers[currentQ];
    };
    oc.appendChild(ta);
    setTimeout(()=>ta.focus(),100);

  } else if(d.type==='media'){
    nb.disabled=!answers[currentQ];
    renderMediaQuestion(oc);
  }
}

// ---- MEDIA QUESTION (Q6) ----
let activeGifTab='search'; // 'search' | 'upload'
let selectedMediaUrl=null;
let selectedMediaType='gif';

function renderMediaQuestion(container){
  selectedMediaUrl = answers[currentQ] ? answers[currentQ].url : null;
  selectedMediaType= answers[currentQ] ? answers[currentQ].mediaType : 'gif';

  container.innerHTML=`
    <div class="gif-search-wrap">
      <div class="gif-tabs">
        <button class="gif-tab${activeGifTab==='search'?' active':''}" onclick="switchGifTab('search')">🔗 Paste URL GIF</button>
        <button class="gif-tab${activeGifTab==='upload'?' active':''}" onclick="switchGifTab('upload')">📤 Upload Gambar</button>
      </div>
      <div id="gifTabContent"></div>
    </div>`;

  renderGifTabContent();
}

function switchGifTab(tab){
  activeGifTab=tab;
  document.querySelectorAll('.gif-tab').forEach((b,i)=>{
    b.classList.toggle('active', (i===0&&tab==='search')||(i===1&&tab==='upload'));
  });
  renderGifTabContent();
}

function renderGifTabContent(){
  const c=document.getElementById('gifTabContent');
  if(!c) return;

  if(activeGifTab==='search'){
    const hasMedia = selectedMediaUrl && selectedMediaType==='gif';
    c.innerHTML=`
      <p style="font-size:.82rem;color:#b090c0;margin-bottom:8px;line-height:1.5;">
        Cari meme di <a href="https://tenor.com" target="_blank" style="color:var(--pink)">tenor.com</a> atau 
        <a href="https://giphy.com" target="_blank" style="color:var(--pink)">giphy.com</a>,<br>
        klik kanan GIF → "Copy image address", lalu paste di sini:
      </p>
      <div class="gif-search-row">
        <input class="gif-search-input" id="gifUrlInput" type="url"
          placeholder="https://media.tenor.com/... atau https://media.giphy.com/..."
          value="${hasMedia ? selectedMediaUrl : ''}">
        <button class="gif-search-btn" onclick="previewGifUrl()">Preview ✨</button>
      </div>
      <div id="gifUrlPreview" style="margin-top:8px;">
        ${hasMedia ? `<img src="${selectedMediaUrl}" style="max-width:100%;max-height:180px;border-radius:12px;border:3px solid var(--pink);" alt="preview"><p style="font-size:.82rem;color:var(--mint);font-family:'Boogaloo',cursive;margin-top:4px;">✅ GIF terpilih!</p>` : ''}
      </div>
      <p style="font-size:.78rem;color:#c0a0d0;margin-top:10px;">💡 Tips: Di Tenor, klik tombol "Share" → "Copy Link" untuk dapat URL langsung</p>
    `;
    const inp = document.getElementById('gifUrlInput');
    if(inp) inp.addEventListener('keydown', e=>{ if(e.key==='Enter') previewGifUrl(); });

  } else {
    const hasMedia = selectedMediaUrl && selectedMediaType==='image';
    c.innerHTML=`
      <div class="upload-area" onclick="document.getElementById('uploadInput').click()">
        <div class="upload-icon">🖼️</div>
        <p>Klik untuk upload gambar<br><span style="font-size:.8rem;">JPG, PNG, GIF, WEBP – maks 5MB</span></p>
      </div>
      <input type="file" id="uploadInput" accept="image/*" onchange="handleUpload(event)">
      <img id="mediaPreview" class="media-preview" src="${hasMedia?selectedMediaUrl:''}" alt="preview" style="display:${hasMedia?'block':'none'}">
      <button class="media-clear" id="mediaClearBtn" style="display:${hasMedia?'inline-block':'none'}" onclick="clearMedia()">✕ Hapus gambar</button>
    `;
  }
}

function previewGifUrl(){
  const inp = document.getElementById('gifUrlInput');
  if(!inp) return;
  const url = inp.value.trim();
  if(!url){ return; }

  // Accept any image-like URL or tenor/giphy share links
  const preview = document.getElementById('gifUrlPreview');
  preview.innerHTML = '<p class="gif-loading">Loading preview... 🐱</p>';

  const img = document.createElement('img');
  img.style.cssText = 'max-width:100%;max-height:180px;border-radius:12px;border:3px solid var(--pink);';
  img.alt = 'GIF preview';
  img.onload = () => {
    preview.innerHTML = '';
    preview.appendChild(img);
    const ok = document.createElement('p');
    ok.style.cssText = "font-size:.82rem;color:var(--mint);font-family:'Boogaloo',cursive;margin-top:4px;";
    ok.textContent = '✅ GIF terpilih!';
    preview.appendChild(ok);
    selectedMediaUrl = url; selectedMediaType = 'gif';
    answers[currentQ] = {url, mediaType:'gif', display:url};
    document.getElementById('quizNextBtn').disabled = false;
  };
  img.onerror = () => {
    preview.innerHTML = `
      <p class="gif-error">Hmm URL-nya ngga bisa dimuat 😅<br>
      <span style="font-size:.78rem">Pastikan kamu copy "image address" (URL langsung ke file .gif/.webp), bukan URL halaman web-nya ya!</span></p>`;
  };
  img.src = url;
}

function handleUpload(e){
  const file=e.target.files[0];
  if(!file) return;
  if(file.size>5*1024*1024){ alert('Gambarnya kegedean, max 5MB ya! 😅'); return; }
  const reader=new FileReader();
  reader.onload=ev=>{
    const url=ev.target.result;
    selectedMediaUrl=url; selectedMediaType='image';
    answers[currentQ]={url, mediaType:'image', display:url};
    const prev=document.getElementById('mediaPreview');
    if(prev){ prev.src=url; prev.style.display='block'; }
    const clr=document.getElementById('mediaClearBtn');
    if(clr) clr.style.display='inline-block';
    document.getElementById('quizNextBtn').disabled=false;
  };
  reader.readAsDataURL(file);
}

function clearMedia(){
  selectedMediaUrl=null; answers[currentQ]=null;
  const prev=document.getElementById('mediaPreview');
  if(prev){ prev.src=''; prev.style.display='none'; }
  const clr=document.getElementById('mediaClearBtn');
  if(clr) clr.style.display='none';
  document.getElementById('quizNextBtn').disabled=true;
}

// ---- CHOICE ----
function selectOption(btn,text){
  document.querySelectorAll('.quiz-opt').forEach(b=>b.classList.remove('selected'));
  btn.classList.add('selected'); answers[currentQ]=text;
  document.getElementById('quizNextBtn').disabled=false;
}

function nextQuestion(){
  if(!answers[currentQ]) return;
  if(currentQ<quizData.length-1){ currentQ++; window._lastGifResults=null; renderQuestion(); }
  else showQuizResult();
}

function showQuizResult(){
  document.getElementById('quizCard').style.display='none';
  document.getElementById('quizResult').style.display='block';
  const shortQs=["Ngga pelupa?","Minum air putih?","Jam tidur?","Yang lebih manja?","Habit paling aneh?","Jadi meme apa?"];
  const rc=document.getElementById('resultCard'); rc.innerHTML='';
  answers.forEach((ans,i)=>{
    const div=document.createElement('div'); div.className='result-item';
    const q=document.createElement('span'); q.className='result-q'; q.textContent=shortQs[i];
    div.appendChild(q);
    if(ans && typeof ans==='object' && ans.url){
      // media answer
      const img=document.createElement('img');
      img.className='result-media'; img.src=ans.display||ans.url; img.alt='meme';
      div.appendChild(img);
    } else {
      const a=document.createElement('span'); a.className='result-a';
      const text=String(ans||'').replace(/[\u{1F300}-\u{1FFFF}]/gu,'').trim().substring(0,40);
      a.textContent=text;
      div.appendChild(a);
    }
    rc.appendChild(div);
  });
  confettiBurst(); window.scrollTo(0,0);
}

// ======= KASETA =======
function showKaseta(){
  const f=document.getElementById('kaseta-frame');
  f.src='https://kaseta.co/play/ebi9licb'; f.style.display='block';
  document.getElementById('kaseta-close').style.display='block';
}
function closeKaseta(){
  const f=document.getElementById('kaseta-frame');
  f.style.display='none'; f.src='';
  document.getElementById('kaseta-close').style.display='none';
}
</script>
</body>
</html>